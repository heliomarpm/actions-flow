{
  "name": "actions-flow-versioning",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "validate": "node versioning.mjs --mode=validate --strict=false --output=versioning-result.json",
    "validate:s": "node versioning.mjs --mode=validate --strict=true --output=versioning-result.json"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.2",
    "@commitlint/lint": "^20.4.2",
    "@commitlint/load": "^20.4.0",
    "@semantic-release/commit-analyzer": "^11.1.0",
    "conventional-commits-parser": "^5.0.0",
    "git-log-parser": "^1.2.1",
    "semantic-release": "^25.0.3",
    "semver": "^7.7.4"
  }
}
